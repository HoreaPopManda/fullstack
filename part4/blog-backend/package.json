{
  "name": "blog-backend",
  "version": "1.0.0",
  "description": "Part 4 fullstack course, blog project",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "node --watch index.js",
    "test": "node --test",
    "build:ui": "rm -rf dist && cd ../blog-frontend && npm run build && cp -r dist ../blog-backend/dist",
